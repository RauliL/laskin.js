{
  "name": "laskin",
  "version": "2.0.0",
  "description": "Implementation of Laskin programming language in JavaScript",
  "license": "MIT",
  "keywords": [
    "calculator",
    "laskin",
    "programming language"
  ],
  "author": "Rauli Laine <rauli.laine@iki.fi>",
  "main": "./dist/index.js",
  "main:src": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "./bin",
    "./dist"
  ],
  "bin": {
    "laskin-js": "./bin/laskin-js"
  },
  "engines": {
    "node": ">=18.0"
  },
  "homepage": "https://rauli.dev/laskin",
  "repository": {
    "type": "git",
    "url": "https://github.com/RauliL/laskin-js"
  },
  "bugs": {
    "url": "https://github.com/RauliL/laskin-js/issues"
  },
  "scripts": {
    "clean": "rimraf './dist'",
    "build": "tsc",
    "watch": "tsc -w",
    "format": "prettier --write './src'",
    "test": "vitest",
    "lint": "eslint './src/**/*.ts'",
    "prebuild": "$npm_execpath run clean",
    "prepack": "$npm_execpath run build"
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "decimal.js": "^10.6.0",
    "strftime": "^0.10.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/strftime": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
